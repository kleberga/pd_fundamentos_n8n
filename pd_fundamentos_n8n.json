      "parameters": {
        "jsCode": "// 1. Acessa todos os itens que chegaram no nó\nconst allItems = $input.all(); \n\n// 2. Mapeia a lista transformando as strings em objetos\nconst processedItems = allItems.map(item => {\n  try {\n    let rawOutput = item.json.output;\n\n    const jsonString = rawOutput\n      .replace(/```json\\n/g, \"\")\n      .replace(/```/g, \"\")\n      .trim();\n\n    const parsedData = JSON.parse(jsonString);\n\n    return {\n      json: parsedData\n    };\n  } catch (error) {\n    return {\n      json: { \n        error: \"Falha ao converter item\", \n        raw: item.json.output \n      }\n    };\n  }\n});\n\nreturn processedItems;"
      },
