      "id": "f6bb88ce-21f1-4aba-91b7-eef5105547a3",
      "name": "Code in Python - notícias encontradas"
    },
    {
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "lista_auxiliar = []\n\nlista_referencias = []\n\nfor item in _items:\n    \n    dados = item.get('json', item) \n\n    if 'output' in dados:\n     \n      string = dados['output'] \n      \n      lista_auxiliar.append(string)\n\n      lista_referencias.append(\"[\" + str(dados[\"id\"]) + \"] \" + dados[\"title\"] + \"\\n\" + dados[\"url\"])\n\nif not lista_auxiliar:\n    return {\n        \"erro\": \"Nenhum campo 'output' encontrado\",\n        \"debug_estrutura_recebida\": _items[0] if _items else \"Sem itens de entrada\"\n    }\n\nmerged_auxiliar = \"\\n\".join(lista_auxiliar)\nmerged_referencias = \"\\n\".join(lista_referencias)\n\nreturn {\n  \"lista_consolidada\": merged_auxiliar,\n  \"lista_referencias\":merged_referencias\n}"
      },
      "type": "n8n-nodes-base.code",
